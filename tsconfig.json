{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "index.ts",
    "tests/**/*.ts"
  ]
}
