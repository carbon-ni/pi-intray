{
  "name": "intray",
  "version": "0.1.0",
  "description": "Control and communicate with running Pi sessions over Unix sockets",
  "type": "module",
  "main": "./index.ts",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "tsx --test tests/**/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage --import tsx tests/**/*.test.ts"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.8.3",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "tsx": "^4.20.5"
  }
}
